# --- MongoDB Atlas ---
# Get this from Atlas > Database > Connect > Drivers. Use a database user
# (not your Atlas login) and make sure your current IP is allow-listed
# under Network Access (or 0.0.0.0/0 for quick testing).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/promptpwn?retryWrites=true&w=majority

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- LLM provider (target personas + judge) ---
# One of: groq | ollama | openrouter
LLM_PROVIDER=groq

# groq — free tier, hosted, works from any cloud backend. Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ollama — fully free, but needs a real Ollama daemon reachable from this
# backend (self-hosted / your own machine or VPS). Install from
# https://ollama.com, then `ollama pull llama3.1:8b` before switching
# LLM_PROVIDER=ollama.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# openrouter — second free-tier fallback. Get a key at
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
